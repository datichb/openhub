# ── get_discovery_agent_id ────────────────────────────────────────────────────

@test "get_discovery_agent_id : lit le champ id: du frontmatter" {
  cat > "$TEST_DIR/project/.opencode/agents/my-agent.md" <<'EOF'
---
id: my-planner
label: MyPlanner
---
# Mon Planner
EOF
  run get_discovery_agent_id "$TEST_DIR/project/.opencode/agents/my-agent.md"
  [ "$status" -eq 0 ]
  [ "$output" = "my-planner" ]
}

@test "get_discovery_agent_id : fallback sur le basename si id: absent" {
  cat > "$TEST_DIR/project/.opencode/agents/custom-reviewer.md" <<'EOF'
# Revieweur custom
Corps.
EOF
  run get_discovery_agent_id "$TEST_DIR/project/.opencode/agents/custom-reviewer.md"
  [ "$status" -eq 0 ]
  [ "$output" = "custom-reviewer" ]
}

@test "get_discovery_agent_id : normalise les majuscules" {
  cat > "$TEST_DIR/project/.opencode/agents/agent-up.md" <<'EOF'
---
id: MyCustomAgent
---
# Agent
EOF
  run get_discovery_agent_id "$TEST_DIR/project/.opencode/agents/agent-up.md"
  [ "$status" -eq 0 ]
  [ "$output" = "mycustomagent" ]
}
