{
  "name": "@openhub/gslides-mcp",
  "version": "1.0.0",
  "private": true,
  "description": "MCP Server for Google Slides integration with OpenCode agents — branding extraction from company templates",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
