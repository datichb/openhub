# Credentials Service Account Google (contenu JSON encodé en base64)
# Obtenir : IAM → Service Accounts → Créer → Télécharger JSON → base64 -i sa-key.json | tr -d '\n'
GOOGLE_SERVICE_ACCOUNT_KEY=BASE64_ENCODED_SA_JSON_HERE

# ID du template Google Slides (facultatif — remplace par l'ID de l'URL : .../presentation/d/{ID}/edit)
# GOOGLE_SLIDES_TEMPLATE_ID=1BxiMxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Timeout des requêtes en ms (facultatif, défaut : 30000)
# GOOGLE_SLIDES_TIMEOUT=30000

# Nombre de tentatives en cas d'erreur réseau (facultatif, défaut : 2)
# GOOGLE_SLIDES_MAX_RETRIES=2
