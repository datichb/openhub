{
  "version": "2.0.0",
  "default_provider": {
    "name": "",
    "api_key": "",
    "base_url": "",
    "model": ""
  },
  "opencode": {
    "model": "claude-sonnet-4-5",
    "disabled_native_agents": [
      "build",
      "plan",
      "general",
      "explore",
      "scout"
    ]
  },
  "agent_models": {
    "families": {},
    "agents": {}
  },
  "cli": {
    "language": "fr"
  },
  "opencode_cache": {
    "provider": {
      "anthropic": {
        "options": {
          "setCacheKey": true
        }
      }
    },
    "compaction": {
      "auto": true,
      "prune": true,
      "reserved": 10000
    }
  }
}
