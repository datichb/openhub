{
  "version": "1.5.0",
  "opencode": {
    "model": "claude-sonnet-4-6",
    "disabled_native_agents": [
      "build",
      "plan",
      "general",
      "explore",
      "scout"
    ]
  },
  "cli": {
    "language": "fr"
  },
  "opencode_cache": {
    "provider": {
      "anthropic": {
        "options": {
          "setCacheKey": true
        }
      }
    },
    "compaction": {
      "auto": true,
      "prune": true,
      "reserved": 10000
    }
  },
  "token_optimization": {
    "output_verbosity": "lite",
    "subagent_verbosity": "subagent",
    "plugins": {
      "rtk": {
        "requires_binary": true,
        "binary": "rtk",
        "min_version": "0.42.0",
        "description": "Réduit les outputs bash (60-90%). Couvre : git diff, git log, find, cat, npm install, etc."
      },
      "context-mode": {
        "requires_npm": true,
        "package": "context-mode",
        "min_node": "22.5.0",
        "description": "Réduit les outputs read/webfetch/MCP (80-98%). Session continuity après compaction. Complémentaire à RTK."
      }
    }
  }
}
