{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Catalogue des fournisseurs LLM — définit la structure et les paramètres par défaut",
  "providers": {
    "anthropic": {
      "label": "Anthropic (direct)",
      "description": "API Anthropic directe pour Claude models",
      "requires_api_key": true,
      "requires_base_url": false,
      "litellm": false,
      "default_model": "claude-sonnet-4-5",
      "supported_targets": [
        "opencode",
        "claude-code"
      ],
      "docs_url": "https://docs.anthropic.com/claude/reference/authentication",
      "opencode_prefix": "anthropic",
      "model_aliases": null
    },
    "mammouth": {
      "label": "MammouthAI",
      "description": "Proxy OpenAI-compatible vers Claude (FR-hosted)",
      "requires_api_key": true,
      "requires_base_url": true,
      "litellm": true,
      "default_base_url": "https://api.mammouth.ai/v1",
      "default_model": "claude-sonnet-4-5",
      "supported_targets": [
        "opencode"
      ],
      "docs_url": "https://mammouth.ai/docs",
      "opencode_prefix": null,
      "model_aliases": null
    },
    "github-models": {
      "label": "GitHub Models",
      "description": "GitHub Models API (Copilot API compatible)",
      "requires_api_key": true,
      "requires_base_url": true,
      "litellm": true,
      "default_base_url": "https://models.inference.ai.azure.com",
      "default_model": "gpt-4o",
      "supported_targets": [
        "opencode"
      ],
      "docs_url": "https://docs.github.com/en/github-models",
      "opencode_prefix": null,
      "model_aliases": null
    },
    "bedrock": {
      "label": "AWS Bedrock (natif)",
      "description": "AWS Bedrock via le provider natif amazon-bedrock d'OpenCode (credentials AWS)",
      "requires_api_key": true,
      "requires_base_url": false,
      "requires_region": true,
      "litellm": false,
      "default_base_url": "",
      "default_region": "eu-west-3",
      "default_model": "claude-sonnet-4-5",
      "supported_targets": [
        "opencode"
      ],
      "docs_url": "https://opencode.ai/docs/providers/#amazon-bedrock",
      "opencode_prefix": "amazon-bedrock",
      "model_aliases": {
        "claude-sonnet-4-5": "anthropic.claude-sonnet-4-5-20250929-v1:0",
        "claude-opus-4": "anthropic.claude-opus-4-5-20251101-v1:0",
        "claude-haiku-4-5": "anthropic.claude-haiku-4-5-20251001-v1:0"
      }
    },
    "ollama": {
      "label": "Ollama (local)",
      "description": "Ollama - LLM local compatible OpenAI",
      "requires_api_key": false,
      "requires_base_url": true,
      "litellm": true,
      "default_base_url": "http://localhost:11434/v1",
      "default_model": "llama3.2",
      "supported_targets": [
        "opencode"
      ],
      "docs_url": "https://ollama.ai",
      "opencode_prefix": null,
      "model_aliases": null
    },
    "github-copilot": {
      "label": "GitHub Copilot",
      "description": "GitHub Copilot API — modèles Claude via Copilot",
      "requires_api_key": false,
      "auth_method": "oauth",
      "requires_base_url": false,
      "litellm": false,
      "default_model": "claude-sonnet-4-5",
      "supported_targets": [
        "opencode"
      ],
      "docs_url": "https://docs.github.com/en/copilot",
      "opencode_prefix": "github-copilot",
      "model_aliases": {
        "claude-sonnet-4-5": "claude-sonnet-4.5",
        "claude-haiku-4-5": "claude-haiku-4.5"
      }
    },
    "openrouter": {
      "label": "OpenRouter",
      "description": "Proxy OpenRouter — accès unifié à de nombreux LLMs via une seule clé API",
      "requires_api_key": true,
      "requires_base_url": false,
      "litellm": false,
      "default_model": "anthropic/claude-sonnet-4-5",
      "supported_targets": [
        "opencode"
      ],
      "docs_url": "https://openrouter.ai/docs/api-reference/overview",
      "opencode_prefix": "openrouter",
      "model_aliases": null
    }
  }
}
